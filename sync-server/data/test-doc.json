        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "highlight",
                "attrs": {
                  "color": "rgb(255, 243, 205)"
                }
              }
            ],
            "text": "马克思主义"
          },
          {
            "type": "text",
            "text": "基本原理指出，"
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "highlight",
                "attrs": {
                  "color": "rgb(255, 243, 205)"
                }
              }
            ],
            "text": "生产力"
          },
          {
            "type": "text",
