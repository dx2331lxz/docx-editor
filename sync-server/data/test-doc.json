          },
          {
            "type": "text",
            "marks": [
              {
                "type": "highlight",
                "attrs": {
                  "color": "rgb(255, 243, 205)"
                }
              }
            ],
            "text": "生产关系"
          },
          {
            "type": "text",
            "text": "，"
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "highlight",
                "attrs": {
                  "color": "rgb(255, 243, 205)"
                }
              }
            ],
            "text": "生产关系"
          },
          {
            "type": "text",
