        "content": [
          {
            "type": "text",
            "marks": [
              {
                "type": "highlight",
                "attrs": {
                  "color": "rgb(255, 243, 205)"
                }
              }
            ],
            "text": "生产力"
          },
          {
            "type": "text",
            "text": "与"
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "highlight",
                "attrs": {
                  "color": "rgb(255, 243, 205)"
                }
              }
            ],
            "text": "生产关系"
